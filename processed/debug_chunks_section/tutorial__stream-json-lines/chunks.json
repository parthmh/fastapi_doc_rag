    "heading_text": "No Return Type",
    "section_url": "https://fastapi.tiangolo.com/tutorial/stream-json-lines/#no-return-type",
    "chunk_index": 0,
    "chunk_text": "No Return Type. You can also omit the return type. FastAPI will then use the jsonable_encoder to convert the data to something that can be serialized to JSON and then send it as JSON Lines.",
