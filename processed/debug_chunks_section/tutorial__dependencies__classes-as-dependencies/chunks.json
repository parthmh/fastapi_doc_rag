    "node_kind": "heading",
    "level": 2,
    "heading_text": "Use it",
    "section_url": "https://fastapi.tiangolo.com/tutorial/dependencies/classes-as-dependencies/#use-it",
    "chunk_index": 0,
    "chunk_text": "Use it. Now you can declare your dependency using this class. FastAPI calls the CommonQueryParams class. This creates an \"instance\" of that class and the instance will be passed as the parameter commons to your function.",
    "token_count": 48,
