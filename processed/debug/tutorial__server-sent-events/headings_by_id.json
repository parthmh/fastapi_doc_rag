  "tutorial/server-sent-events::section-0002": {
    "node_id": "tutorial/server-sent-events::section-0002",
    "parent_id": "tutorial/server-sent-events::section-0001",
    "level": 2,
    "node_kind": "heading",
    "heading_text": "What are Server-Sent Events?",
    "anchor_id": "what-are-server-sent-events",
    "section_url": "https://fastapi.tiangolo.com/tutorial/server-sent-events/#what-are-server-sent-events",
    "section_text": "SSE is a standard for streaming data from the server to the client over HTTP.\n\nEach event is a small text block with \"fields\" like data , event , id , and retry , separated by blank lines.\n\nIt looks like this:\n\nSSE is commonly used for AI chat streaming, live notifications, logs and observability, and other cases where the server pushes updates to the client.",
    "section_inline_code": [
      "data",
      "event",
      "id",
      "retry"
    ],
    "section_links": [],
    "code_refs": [],
    "code_blocks": [
      {
        "type": "code_block",
        "language": null,
        "text": "data: {\"name\": \"Portal Gun\", \"price\": 999.99}\n\ndata: {\"name\": \"Plumbus\", \"price\": 32.99}",
        "section_id": "tutorial/server-sent-events::section-0002",
        "section_url": "https://fastapi.tiangolo.com/tutorial/server-sent-events/#what-are-server-sent-events"
      }
    ]
  },
  "tutorial/server-sent-events::section-0003": {
    "node_id": "tutorial/server-sent-events::section-0003",
    "parent_id": "tutorial/server-sent-events::section-0001",
    "level": 2,
    "node_kind": "heading",
    "heading_text": "Stream SSE with FastAPI",
    "anchor_id": "stream-sse-with-fastapi",
    "section_url": "https://fastapi.tiangolo.com/tutorial/server-sent-events/#stream-sse-with-fastapi",
    "section_text": "To stream SSE with FastAPI, use yield in your path operation function and set response_class=EventSourceResponse .\n\nImport EventSourceResponse from fastapi.sse :\n\nEach yielded item is encoded as JSON and sent in the data: field of an SSE event.\n\nIf you declare the return type as AsyncIterable[Item] , FastAPI will use it to validate , document , and serialize the data using Pydantic.",
    "section_inline_code": [
      "yield",
      "response_class=EventSourceResponse",
      "EventSourceResponse",
      "fastapi.sse",
      "data:",
      "AsyncIterable[Item]"
    ],
