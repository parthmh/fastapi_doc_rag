    "node_kind": "heading",
    "heading_text": "Server-Sent Events (SSE)",
    "anchor_id": "server-sent-events-sse",
    "section_url": "https://fastapi.tiangolo.com/tutorial/server-sent-events/#server-sent-events-sse",
    "section_text": "You can stream data to the client using Server-Sent Events (SSE).\n\nThis is similar to Stream JSON Lines , but uses the text/event-stream format, which is supported natively by browsers with the EventSource API .",
    "section_inline_code": [
      "text/event-stream",
      "EventSource"
    ],
    "section_links": [
