  "tutorial/server-sent-events::section-0010": {
    "node_id": "tutorial/server-sent-events::section-0010",
    "parent_id": "tutorial/server-sent-events::section-0001",
    "level": 2,
    "node_kind": "heading",
    "heading_text": "Technical Details",
    "anchor_id": "technical-details",
    "section_url": "https://fastapi.tiangolo.com/tutorial/server-sent-events/#technical-details",
    "section_text": "FastAPI implements some SSE best practices out of the box.\n\n- Send a \"keep alive\" ping comment every 15 seconds when there hasn't been any message, to prevent some proxies from closing the connection, as suggested in the HTML specification: Server-Sent Events .\n\n- Set the Cache-Control: no-cache header to prevent caching of the stream.\n\n- Set a special header X-Accel-Buffering: no to prevent buffering in some proxies like Nginx.\n\nYou don't have to do anything about it, it works out of the box. 🤓",
    "section_inline_code": [
      "ping",
      "Cache-Control: no-cache",
      "X-Accel-Buffering: no"
    ],
    "section_links": [
      {
        "text": "HTML specification: Server-Sent Events",
        "url": "https://html.spec.whatwg.org/multipage/server-sent-events.html#authoring-notes",
        "section_id": "tutorial/server-sent-events::section-0010",
        "section_url": "https://fastapi.tiangolo.com/tutorial/server-sent-events/#technical-details"
      }
    ],
    "code_refs": [],
    "code_blocks": []
  }
