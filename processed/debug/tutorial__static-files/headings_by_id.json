  "tutorial/static-files::section-0003": {
    "node_id": "tutorial/static-files::section-0003",
    "parent_id": "tutorial/static-files::section-0002",
    "level": 3,
    "node_kind": "heading",
    "heading_text": "What is \"Mounting\"",
    "anchor_id": "what-is-mounting",
    "section_url": "https://fastapi.tiangolo.com/tutorial/static-files/#what-is-mounting",
    "section_text": "\"Mounting\" means adding a complete \"independent\" application in a specific path, that then takes care of handling all the sub-paths.\n\nThis is different from using an APIRouter as a mounted application is completely independent. The OpenAPI and docs from your main application won't include anything from the mounted application, etc.\n\nYou can read more about this in the Advanced User Guide .",
    "section_inline_code": [
      "APIRouter"
    ],
    "section_links": [
      {
        "text": "Advanced User Guide",
        "url": "../advanced/index.md",
        "section_id": "tutorial/static-files::section-0003",
        "section_url": "https://fastapi.tiangolo.com/tutorial/static-files/#what-is-mounting"
      }
    ],
