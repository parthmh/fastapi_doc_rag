  "tutorial/static-files::section-0004": {
    "node_id": "tutorial/static-files::section-0004",
    "parent_id": "tutorial/static-files::section-0001",
    "level": 2,
    "node_kind": "heading",
    "heading_text": "Details",
    "anchor_id": "details",
    "section_url": "https://fastapi.tiangolo.com/tutorial/static-files/#details",
    "section_text": "The first \"/static\" refers to the sub-path this \"sub-application\" will be \"mounted\" on. So, any path that starts with \"/static\" will be handled by it.\n\nThe directory=\"static\" refers to the name of the directory that contains your static files.\n\nThe name=\"static\" gives it a name that can be used internally by FastAPI .\n\nAll these parameters can be different than \" static \", adjust them with the needs and specific details of your own application.",
    "section_inline_code": [
      "\"/static\"",
      "directory=\"static\"",
      "name=\"static\"",
      "static"
    ],
    "section_links": [],
    "code_refs": [],
    "code_blocks": []
  },
