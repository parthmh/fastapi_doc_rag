        {
          "node_id": "tutorial/request-form-models::section-0004",
          "parent_id": "tutorial/request-form-models::section-0001",
          "level": 2,
          "node_kind": "heading",
          "heading_text": "Forbid Extra Form Fields",
          "anchor_id": "forbid-extra-form-fields",
          "section_url": "https://fastapi.tiangolo.com/tutorial/request-form-models/#forbid-extra-form-fields",
          "section_text_parts": [
            "In some special use cases (probably not very common), you might want to restrict the form fields to only those declared in the Pydantic model. And forbid any extra fields.",
            "You can use Pydantic's model configuration to forbid any extra fields:",
            "If a client tries to send some extra data, they will receive an error response.",
            "For example, if the client tries to send the form fields:",
            "- username : Rick",
            "- password : Portal Gun",
            "- extra : Mr. Poopybutthole",
            "They will receive an error response telling them that the field extra is not allowed:"
          ],
          "section_text": "In some special use cases (probably not very common), you might want to restrict the form fields to only those declared in the Pydantic model. And forbid any extra fields.\n\nYou can use Pydantic's model configuration to forbid any extra fields:\n\nIf a client tries to send some extra data, they will receive an error response.\n\nFor example, if the client tries to send the form fields:\n\n- username : Rick\n\n- password : Portal Gun\n\n- extra : Mr. Poopybutthole\n\nThey will receive an error response telling them that the field extra is not allowed:",
          "section_inline_code": [
            "forbid",
            "extra",
            "username",
            "Rick",
            "password",
            "Portal Gun",
            "Mr. Poopybutthole"
          ],
          "section_links": [],
          "code_refs": [
            {
              "type": "code_ref",
              "path": "../../docs_src/request_form_models/tutorial002_an_py310.py",
              "highlight_lines": [
                12
              ],
              "raw": "{* ../../docs_src/request_form_models/tutorial002_an_py310.py hl[12] *}",
              "section_id": "tutorial/request-form-models::section-0004",
              "section_url": "https://fastapi.tiangolo.com/tutorial/request-form-models/#forbid-extra-form-fields"
            }
          ],
          "code_blocks": [
            {
              "type": "code_block",
              "language": "json",
              "text": "{\n    \"detail\": [\n        {\n            \"type\": \"extra_forbidden\",\n            \"loc\": [\"body\", \"extra\"],\n            \"msg\": \"Extra inputs are not permitted\",\n            \"input\": \"Mr. Poopybutthole\"\n        }\n    ]\n}",
              "section_id": "tutorial/request-form-models::section-0004",
              "section_url": "https://fastapi.tiangolo.com/tutorial/request-form-models/#forbid-extra-form-fields"
            }
          ],
