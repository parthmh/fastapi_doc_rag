  "tutorial/query-param-models::section-0004": {
    "node_id": "tutorial/query-param-models::section-0004",
    "parent_id": "tutorial/query-param-models::section-0001",
    "level": 2,
    "node_kind": "heading",
    "heading_text": "Forbid Extra Query Parameters",
    "anchor_id": "forbid-extra-query-parameters",
    "section_url": "https://fastapi.tiangolo.com/tutorial/query-param-models/#forbid-extra-query-parameters",
    "section_text": "In some special use cases (probably not very common), you might want to restrict the query parameters that you want to receive.\n\nYou can use Pydantic's model configuration to forbid any extra fields:\n\nIf a client tries to send some extra data in the query parameters , they will receive an error response.\n\nFor example, if the client tries to send a tool query parameter with a value of plumbus , like:\n\nThey will receive an error response telling them that the query parameter tool is not allowed:",
    "section_inline_code": [
      "forbid",
      "extra",
      "tool",
      "plumbus"
    ],
    "section_links": [],
    "code_refs": [
      {
        "type": "code_ref",
        "path": "../../docs_src/query_param_models/tutorial002_an_py310.py",
        "highlight_lines": [
          10
        ],
        "raw": "{* ../../docs_src/query_param_models/tutorial002_an_py310.py hl[10] *}",
        "section_id": "tutorial/query-param-models::section-0004",
        "section_url": "https://fastapi.tiangolo.com/tutorial/query-param-models/#forbid-extra-query-parameters"
      }
    ],
    "code_blocks": [
      {
        "type": "code_block",
        "language": "http",
        "text": "https://example.com/items/?limit=10&tool=plumbus",
        "section_id": "tutorial/query-param-models::section-0004",
        "section_url": "https://fastapi.tiangolo.com/tutorial/query-param-models/#forbid-extra-query-parameters"
      },
      {
        "type": "code_block",
        "language": "json",
        "text": "{\n    \"detail\": [\n        {\n            \"type\": \"extra_forbidden\",\n            \"loc\": [\"query\", \"tool\"],\n            \"msg\": \"Extra inputs are not permitted\",\n            \"input\": \"plumbus\"\n        }\n    ]\n}",
        "section_id": "tutorial/query-param-models::section-0004",
        "section_url": "https://fastapi.tiangolo.com/tutorial/query-param-models/#forbid-extra-query-parameters"
      }
    ]
  },
