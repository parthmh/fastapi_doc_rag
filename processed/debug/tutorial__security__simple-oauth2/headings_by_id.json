  "tutorial/security/simple-oauth2::section-0005": {
    "node_id": "tutorial/security/simple-oauth2::section-0005",
    "parent_id": "tutorial/security/simple-oauth2::section-0004",
    "level": 3,
    "node_kind": "heading",
    "heading_text": "OAuth2PasswordRequestForm",
    "anchor_id": "oauth2passwordrequestform",
    "section_url": "https://fastapi.tiangolo.com/tutorial/security/simple-oauth2/#oauth2passwordrequestform",
    "section_text": "First, import OAuth2PasswordRequestForm , and use it as a dependency with Depends in the path operation for /token :\n\nOAuth2PasswordRequestForm is a class dependency that declares a form body with:\n\n- The username .\n\n- The password .\n\n- An optional scope field as a big string, composed of strings separated by spaces.\n\n- An optional grant_type .\n\n- An optional client_id (we don't need it for our example).\n\n- An optional client_secret (we don't need it for our example).",
    "section_inline_code": [
      "OAuth2PasswordRequestForm",
      "Depends",
      "/token",
      "username",
      "password",
      "scope",
      "grant_type",
      "client_id",
      "client_secret"
    ],
    "section_links": [],
    "code_refs": [
      {
        "type": "code_ref",
        "path": "../../docs_src/security/tutorial003_an_py310.py",
        "highlight_lines": [
