  "tutorial/security/simple-oauth2::section-0007": {
    "node_id": "tutorial/security/simple-oauth2::section-0007",
    "parent_id": "tutorial/security/simple-oauth2::section-0004",
    "level": 3,
    "node_kind": "heading",
    "heading_text": "Check the password",
    "anchor_id": "check-the-password",
    "section_url": "https://fastapi.tiangolo.com/tutorial/security/simple-oauth2/#check-the-password",
    "section_text": "At this point we have the user data from our database, but we haven't checked the password.\n\nLet's put that data in the Pydantic UserInDB model first.\n\nYou should never save plaintext passwords, so, we'll use the (fake) password hashing system.\n\nIf the passwords don't match, we return the same error.",
    "section_inline_code": [
      "UserInDB"
    ],
    "section_links": [],
    "code_refs": [],
    "code_blocks": []
  },
  "tutorial/security/simple-oauth2::section-0008": {
    "node_id": "tutorial/security/simple-oauth2::section-0008",
    "parent_id": "tutorial/security/simple-oauth2::section-0007",
    "level": 4,
    "node_kind": "heading",
    "heading_text": "Password hashing",
    "anchor_id": "password-hashing",
    "section_url": "https://fastapi.tiangolo.com/tutorial/security/simple-oauth2/#password-hashing",
    "section_text": "\"Hashing\" means: converting some content (a password in this case) into a sequence of bytes (just a string) that looks like gibberish.\n\nWhenever you pass exactly the same content (exactly the same password) you get exactly the same gibberish.\n\nBut you cannot convert from the gibberish back to the password.",
    "section_inline_code": [],
    "section_links": [],
    "code_refs": [],
    "code_blocks": []
  },
  "tutorial/security/simple-oauth2::section-0009": {
    "node_id": "tutorial/security/simple-oauth2::section-0009",
    "parent_id": "tutorial/security/simple-oauth2::section-0008",
    "level": 5,
    "node_kind": "heading",
    "heading_text": "Why use password hashing",
    "anchor_id": "why-use-password-hashing",
    "section_url": "https://fastapi.tiangolo.com/tutorial/security/simple-oauth2/#why-use-password-hashing",
    "section_text": "If your database is stolen, the thief won't have your users' plaintext passwords, only the hashes.\n\nSo, the thief won't be able to try to use those same passwords in another system (as many users use the same password everywhere, this would be dangerous).",
    "section_inline_code": [],
    "section_links": [],
    "code_refs": [
      {
        "type": "code_ref",
        "path": "../../docs_src/security/tutorial003_an_py310.py",
        "highlight_lines": [
          82,
          83,
          84,
          85
        ],
        "raw": "{* ../../docs_src/security/tutorial003_an_py310.py hl[82:85] *}",
        "section_id": "tutorial/security/simple-oauth2::section-0009",
        "section_url": "https://fastapi.tiangolo.com/tutorial/security/simple-oauth2/#why-use-password-hashing"
      }
    ],
    "code_blocks": []
  },
  "tutorial/security/simple-oauth2::section-0010": {
    "node_id": "tutorial/security/simple-oauth2::section-0010",
    "parent_id": "tutorial/security/simple-oauth2::section-0007",
    "level": 4,
    "node_kind": "heading",
    "heading_text": "About **user_dict",
    "anchor_id": "about-user-dict",
    "section_url": "https://fastapi.tiangolo.com/tutorial/security/simple-oauth2/#about-user-dict",
    "section_text": "UserInDB(**user_dict) means:\n\nPass the keys and values of the user_dict directly as key-value arguments, equivalent to:",
    "section_inline_code": [
      "**user_dict",
      "UserInDB(**user_dict)",
      "user_dict"
    ],
    "section_links": [],
    "code_refs": [],
    "code_blocks": [
      {
        "type": "code_block",
        "language": "Python",
        "text": "UserInDB(\n    username = user_dict[\"username\"],\n    email = user_dict[\"email\"],\n    full_name = user_dict[\"full_name\"],\n    disabled = user_dict[\"disabled\"],\n    hashed_password = user_dict[\"hashed_password\"],\n)",
        "section_id": "tutorial/security/simple-oauth2::section-0010",
        "section_url": "https://fastapi.tiangolo.com/tutorial/security/simple-oauth2/#about-user-dict"
      }
    ]
  },
  "tutorial/security/simple-oauth2::section-0011": {
    "node_id": "tutorial/security/simple-oauth2::section-0011",
    "parent_id": "tutorial/security/simple-oauth2::section-0001",
    "level": 2,
    "node_kind": "heading",
    "heading_text": "Return the token",
    "anchor_id": "return-the-token",
    "section_url": "https://fastapi.tiangolo.com/tutorial/security/simple-oauth2/#return-the-token",
    "section_text": "The response of the token endpoint must be a JSON object.\n\nIt should have a token_type . In our case, as we are using \"Bearer\" tokens, the token type should be \" bearer \".\n\nAnd it should have an access_token , with a string containing our access token.\n\nFor this simple example, we are going to just be completely insecure and return the same username as the token.",
    "section_inline_code": [
      "token",
      "token_type",
      "bearer",
      "access_token",
      "username"
    ],
    "section_links": [],
    "code_refs": [
      {
