  "tutorial/security/simple-oauth2::section-0015": {
    "node_id": "tutorial/security/simple-oauth2::section-0015",
    "parent_id": "tutorial/security/simple-oauth2::section-0013",
    "level": 3,
    "node_kind": "heading",
    "heading_text": "Get your own user data",
    "anchor_id": "get-your-own-user-data",
    "section_url": "https://fastapi.tiangolo.com/tutorial/security/simple-oauth2/#get-your-own-user-data",
    "section_text": "Now use the operation GET with the path /users/me .\n\nYou will get your user's data, like:\n\nIf you click the lock icon and logout, and then try the same operation again, you will get an HTTP 401 error of:",
    "section_inline_code": [
      "GET",
      "/users/me"
    ],
    "section_links": [],
    "code_refs": [],
    "code_blocks": [
      {
        "type": "code_block",
        "language": "JSON",
        "text": "{\n  \"username\": \"johndoe\",\n  \"email\": \"johndoe@example.com\",\n  \"full_name\": \"John Doe\",\n  \"disabled\": false,\n  \"hashed_password\": \"fakehashedsecret\"\n}",
        "section_id": "tutorial/security/simple-oauth2::section-0015",
