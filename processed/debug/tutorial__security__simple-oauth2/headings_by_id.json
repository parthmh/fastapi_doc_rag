        ],
        "raw": "{* ../../docs_src/security/tutorial003_an_py310.py hl[4,78] *}",
        "section_id": "tutorial/security/simple-oauth2::section-0005",
        "section_url": "https://fastapi.tiangolo.com/tutorial/security/simple-oauth2/#oauth2passwordrequestform"
      }
    ],
    "code_blocks": []
