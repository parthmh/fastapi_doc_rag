  "tutorial/query-params-str-validations::section-0021": {
    "node_id": "tutorial/query-params-str-validations::section-0021",
    "parent_id": "tutorial/query-params-str-validations::section-0001",
    "level": 2,
    "node_kind": "heading",
    "heading_text": "Custom Validation",
    "anchor_id": "custom-validation",
    "section_url": "https://fastapi.tiangolo.com/tutorial/query-params-str-validations/#custom-validation",
    "section_text": "There could be cases where you need to do some custom validation that can't be done with the parameters shown above.\n\nIn those cases, you can use a custom validator function that is applied after the normal validation (e.g. after validating that the value is a str ).\n\nYou can achieve that using Pydantic's AfterValidator inside of Annotated .\n\nFor example, this custom validator checks that the item ID starts with isbn- for an ISBN book number or with imdb- for an IMDB movie URL ID:",
    "section_inline_code": [
      "str",
      "AfterValidator",
      "Annotated",
      "isbn-",
      "imdb-"
    ],
    "section_links": [
      {
        "text": "Pydantic's",
        "url": "https://docs.pydantic.dev/latest/concepts/validators/#field-after-validator",
        "section_id": "tutorial/query-params-str-validations::section-0021",
        "section_url": "https://fastapi.tiangolo.com/tutorial/query-params-str-validations/#custom-validation"
      }
    ],
    "code_refs": [
      {
        "type": "code_ref",
        "path": "../../docs_src/query_params_str_validations/tutorial015_an_py310.py",
        "highlight_lines": [
          5,
          16,
          17,
          18,
          19,
          24
        ],
        "raw": "{* ../../docs_src/query_params_str_validations/tutorial015_an_py310.py hl[5,16:19,24] *}",
        "section_id": "tutorial/query-params-str-validations::section-0021",
        "section_url": "https://fastapi.tiangolo.com/tutorial/query-params-str-validations/#custom-validation"
      }
    ],
