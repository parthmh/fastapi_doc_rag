    "node_kind": "heading",
    "heading_text": "Special types and validation",
    "anchor_id": "special-types-and-validation",
    "section_url": "https://fastapi.tiangolo.com/tutorial/body-nested-models/#special-types-and-validation",
    "section_text": "Apart from normal singular types like str , int , float , etc. you can use more complex singular types that inherit from str .\n\nTo see all the options you have, checkout Pydantic's Type Overview . You will see some examples in the next chapter.\n\nFor example, as in the Image model we have a url field, we can declare it to be an instance of Pydantic's HttpUrl instead of a str :\n\nThe string will be checked to be a valid URL, and documented in JSON Schema / OpenAPI as such.",
    "section_inline_code": [
      "str",
      "int",
      "float",
      "Image",
      "url",
      "HttpUrl"
    ],
    "section_links": [
      {
        "text": "Pydantic's Type Overview",
        "url": "https://docs.pydantic.dev/latest/concepts/types/",
        "section_id": "tutorial/body-nested-models::section-0009",
