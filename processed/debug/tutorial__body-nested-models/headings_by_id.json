        "raw": "{* ../../docs_src/body_nested_models/tutorial004_py310.py hl[18] *}",
        "section_id": "tutorial/body-nested-models::section-0008",
        "section_url": "https://fastapi.tiangolo.com/tutorial/body-nested-models/#use-the-submodel-as-a-type"
      }
    ],
    "code_blocks": [
