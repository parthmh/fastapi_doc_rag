  "tutorial/body-nested-models::section-0012": {
    "node_id": "tutorial/body-nested-models::section-0012",
    "parent_id": "tutorial/body-nested-models::section-0001",
    "level": 2,
    "node_kind": "heading",
    "heading_text": "Bodies of pure lists",
    "anchor_id": "bodies-of-pure-lists",
    "section_url": "https://fastapi.tiangolo.com/tutorial/body-nested-models/#bodies-of-pure-lists",
    "section_text": "If the top level value of the JSON body you expect is a JSON array (a Python list ), you can declare the type in the parameter of the function, the same as in Pydantic models:\n\nas in:",
    "section_inline_code": [
      "array",
      "list"
    ],
    "section_links": [],
    "code_refs": [
      {
        "type": "code_ref",
        "path": "../../docs_src/body_nested_models/tutorial008_py310.py",
