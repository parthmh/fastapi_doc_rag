  "tutorial/body-multiple-params::section-0007": {
    "node_id": "tutorial/body-multiple-params::section-0007",
    "parent_id": "tutorial/body-multiple-params::section-0001",
    "level": 2,
    "node_kind": "heading",
    "heading_text": "Recap",
    "anchor_id": "recap",
    "section_url": "https://fastapi.tiangolo.com/tutorial/body-multiple-params/#recap",
    "section_text": "You can add multiple body parameters to your path operation function , even though a request can only have a single body.\n\nBut FastAPI will handle it, give you the correct data in your function, and validate and document the correct schema in the path operation .\n\nYou can also declare singular values to be received as part of the body.\n\nAnd you can instruct FastAPI to embed the body in a key even when there is only a single parameter declared.",
    "section_inline_code": [],
    "section_links": [],
