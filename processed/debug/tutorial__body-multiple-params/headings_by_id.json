        "section_id": "tutorial/body-multiple-params::section-0006",
        "section_url": "https://fastapi.tiangolo.com/tutorial/body-multiple-params/#embed-a-single-body-parameter"
      },
      {
        "type": "code_block",
        "language": "JSON",
        "text": "{\n    \"name\": \"Foo\",\n    \"description\": \"The pretender\",\n    \"price\": 42.0,\n    \"tax\": 3.2\n}",
