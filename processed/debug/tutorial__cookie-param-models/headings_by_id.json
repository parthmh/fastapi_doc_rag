  "tutorial/cookie-param-models::section-0004": {
    "node_id": "tutorial/cookie-param-models::section-0004",
    "parent_id": "tutorial/cookie-param-models::section-0001",
    "level": 2,
    "node_kind": "heading",
    "heading_text": "Forbid Extra Cookies",
    "anchor_id": "forbid-extra-cookies",
    "section_url": "https://fastapi.tiangolo.com/tutorial/cookie-param-models/#forbid-extra-cookies",
    "section_text": "In some special use cases (probably not very common), you might want to restrict the cookies that you want to receive.\n\nYour API now has the power to control its own cookie consent . 🤪🍪\n\nYou can use Pydantic's model configuration to forbid any extra fields:\n\nIf a client tries to send some extra cookies , they will receive an error response.\n\nPoor cookie banners with all their effort to get your consent for the API to reject it . 🍪\n\nFor example, if the client tries to send a santa_tracker cookie with a value of good-list-please , the client will receive an error response telling them that the santa_tracker cookie is not allowed :",
    "section_inline_code": [
      "forbid",
      "extra",
      "santa_tracker",
      "good-list-please"
    ],
    "section_links": [],
    "code_refs": [
      {
        "type": "code_ref",
        "path": "../../docs_src/cookie_param_models/tutorial002_an_py310.py",
        "highlight_lines": [
          10
        ],
        "raw": "{* ../../docs_src/cookie_param_models/tutorial002_an_py310.py hl[10] *}",
        "section_id": "tutorial/cookie-param-models::section-0004",
        "section_url": "https://fastapi.tiangolo.com/tutorial/cookie-param-models/#forbid-extra-cookies"
      }
    ],
    "code_blocks": [
      {
        "type": "code_block",
        "language": "json",
        "text": "{\n    \"detail\": [\n        {\n            \"type\": \"extra_forbidden\",\n            \"loc\": [\"cookie\", \"santa_tracker\"],\n            \"msg\": \"Extra inputs are not permitted\",\n            \"input\": \"good-list-please\",\n        }\n    ]\n}",
        "section_id": "tutorial/cookie-param-models::section-0004",
        "section_url": "https://fastapi.tiangolo.com/tutorial/cookie-param-models/#forbid-extra-cookies"
      }
    ]
  },
