  "tutorial/testing::section-0009": {
    "node_id": "tutorial/testing::section-0009",
    "parent_id": "tutorial/testing::section-0001",
    "level": 2,
    "node_kind": "heading",
    "heading_text": "Run it",
    "anchor_id": "run-it",
    "section_url": "https://fastapi.tiangolo.com/tutorial/testing/#run-it",
    "section_text": "After that, you just need to install pytest .\n\nMake sure you create a virtual environment , activate it, and then install it, for example:\n\nIt will detect the files and tests automatically, execute them, and report the results back to you.\n\nRun the tests with:",
    "section_inline_code": [
      "pytest"
    ],
    "section_links": [
      {
        "text": "virtual environment",
        "url": "../virtual-environments.md",
        "section_id": "tutorial/testing::section-0009",
        "section_url": "https://fastapi.tiangolo.com/tutorial/testing/#run-it"
      }
    ],
    "code_refs": [],
    "code_blocks": [
      {
        "type": "code_block",
        "language": "console",
        "text": "$ pip install pytest\n\n---> 100%",
        "section_id": "tutorial/testing::section-0009",
        "section_url": "https://fastapi.tiangolo.com/tutorial/testing/#run-it"
      },
      {
        "type": "code_block",
        "language": "console",
        "text": "$ pytest\n\n================ test session starts ================\nplatform linux -- Python 3.6.9, pytest-5.3.5, py-1.8.1, pluggy-0.13.1\nrootdir: /home/user/code/superawesome-cli/app\nplugins: forked-1.1.3, xdist-1.31.0, cov-2.8.1\ncollected 6 items\n\n---> 100%\n\ntest_main.py <span style=\"color: green; white-space: pre;\">......                            [100%]</span>\n\n<span style=\"color: green;\">================= 1 passed in 0.03s =================</span>",
        "section_id": "tutorial/testing::section-0009",
        "section_url": "https://fastapi.tiangolo.com/tutorial/testing/#run-it"
      }
    ]
  }
