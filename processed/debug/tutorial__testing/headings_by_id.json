  "tutorial/testing::section-0007": {
    "node_id": "tutorial/testing::section-0007",
    "parent_id": "tutorial/testing::section-0006",
    "level": 3,
    "node_kind": "heading",
    "heading_text": "Extended FastAPI app file",
    "anchor_id": "extended-fastapi-app-file",
    "section_url": "https://fastapi.tiangolo.com/tutorial/testing/#extended-fastapi-app-file",
    "section_text": "Let's continue with the same file structure as before:\n\nLet's say that now the file main.py with your FastAPI app has some other path operations .\n\nIt has a GET operation that could return an error.\n\nIt has a POST operation that could return several errors.\n\nBoth path operations require an X-Token header.",
    "section_inline_code": [
      "main.py",
      "GET",
      "POST",
      "X-Token"
    ],
    "section_links": [],
    "code_refs": [
      {
        "type": "code_ref",
        "path": "../../docs_src/app_testing/app_b_an_py310/main.py",
        "highlight_lines": [],
        "raw": "{* ../../docs_src/app_testing/app_b_an_py310/main.py *}",
        "section_id": "tutorial/testing::section-0007",
        "section_url": "https://fastapi.tiangolo.com/tutorial/testing/#extended-fastapi-app-file"
      }
    ],
    "code_blocks": [
      {
        "type": "code_block",
        "language": null,
        "text": ".\n├── app\n│   ├── __init__.py\n│   ├── main.py\n│   └── test_main.py",
        "section_id": "tutorial/testing::section-0007",
        "section_url": "https://fastapi.tiangolo.com/tutorial/testing/#extended-fastapi-app-file"
      }
    ]
