  "tutorial/body-updates::section-0006": {
    "node_id": "tutorial/body-updates::section-0006",
    "parent_id": "tutorial/body-updates::section-0004",
    "level": 3,
    "node_kind": "heading",
    "heading_text": "Using Pydantic's update parameter",
    "anchor_id": "using-pydantics-update-parameter",
    "section_url": "https://fastapi.tiangolo.com/tutorial/body-updates/#using-pydantics-update-parameter",
    "section_text": "Now, you can create a copy of the existing model using .model_copy() , and pass the update parameter with a dict containing the data to update.\n\nLike stored_item_model.model_copy(update=update_data) :",
    "section_inline_code": [
      "update",
      ".model_copy()",
      "dict",
      "stored_item_model.model_copy(update=update_data)"
    ],
