  "tutorial/body-updates::section-0005": {
    "node_id": "tutorial/body-updates::section-0005",
    "parent_id": "tutorial/body-updates::section-0004",
    "level": 3,
    "node_kind": "heading",
    "heading_text": "Using Pydantic's exclude_unset parameter",
    "anchor_id": "using-pydantics-exclude-unset-parameter",
    "section_url": "https://fastapi.tiangolo.com/tutorial/body-updates/#using-pydantics-exclude-unset-parameter",
    "section_text": "If you want to receive partial updates, it's very useful to use the parameter exclude_unset in Pydantic's model's .model_dump() .\n\nLike item.model_dump(exclude_unset=True) .\n\nThat would generate a dict with only the data that was set when creating the item model, excluding default values.\n\nThen you can use this to generate a dict with only the data that was set (sent in the request), omitting default values:",
    "section_inline_code": [
      "exclude_unset",
      ".model_dump()",
      "item.model_dump(exclude_unset=True)",
      "dict",
      "item"
    ],
    "section_links": [],
    "code_refs": [
      {
        "type": "code_ref",
        "path": "../../docs_src/body_updates/tutorial002_py310.py",
        "highlight_lines": [
