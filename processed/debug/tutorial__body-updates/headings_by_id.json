    "level": 2,
    "node_kind": "heading",
    "heading_text": "Update replacing with PUT",
    "anchor_id": "update-replacing-with-put",
    "section_url": "https://fastapi.tiangolo.com/tutorial/body-updates/#update-replacing-with-put",
    "section_text": "To update an item you can use the HTTP PUT operation.\n\nYou can use the jsonable_encoder to convert the input data to data that can be stored as JSON (e.g. with a NoSQL database). For example, converting datetime to str .\n\nPUT is used to receive data that should replace the existing data.",
    "section_inline_code": [
      "PUT",
      "jsonable_encoder",
      "datetime",
      "str"
    ],
    "section_links": [
      {
        "text": "HTTP",
        "url": "https://developer.mozilla.org/en-US/docs/Web/HTTP/Methods/PUT",
        "section_id": "tutorial/body-updates::section-0002",
        "section_url": "https://fastapi.tiangolo.com/tutorial/body-updates/#update-replacing-with-put"
      }
    ],
