  "tutorial/body-updates::section-0003": {
    "node_id": "tutorial/body-updates::section-0003",
    "parent_id": "tutorial/body-updates::section-0002",
    "level": 3,
    "node_kind": "heading",
    "heading_text": "Warning about replacing",
    "anchor_id": "warning-about-replacing",
    "section_url": "https://fastapi.tiangolo.com/tutorial/body-updates/#warning-about-replacing",
    "section_text": "That means that if you want to update the item bar using PUT with a body containing:\n\nbecause it doesn't include the already stored attribute \"tax\": 20.2 , the input model would take the default value of \"tax\": 10.5 .\n\nAnd the data would be saved with that \"new\" tax of 10.5 .",
    "section_inline_code": [
      "bar",
      "PUT",
      "\"tax\": 20.2",
      "\"tax\": 10.5",
      "tax",
      "10.5"
    ],
    "section_links": [],
    "code_refs": [],
    "code_blocks": [
      {
        "type": "code_block",
        "language": "Python",
        "text": "{\n    \"name\": \"Barz\",\n    \"price\": 3,\n    \"description\": None,\n}",
        "section_id": "tutorial/body-updates::section-0003",
        "section_url": "https://fastapi.tiangolo.com/tutorial/body-updates/#warning-about-replacing"
      }
    ]
  },
  "tutorial/body-updates::section-0004": {
    "node_id": "tutorial/body-updates::section-0004",
    "parent_id": "tutorial/body-updates::section-0001",
    "level": 2,
    "node_kind": "heading",
    "heading_text": "Partial updates with PATCH",
    "anchor_id": "partial-updates-with-patch",
    "section_url": "https://fastapi.tiangolo.com/tutorial/body-updates/#partial-updates-with-patch",
    "section_text": "You can also use the HTTP PATCH operation to partially update data.\n\nThis means that you can send only the data that you want to update, leaving the rest intact.",
    "section_inline_code": [
      "PATCH"
    ],
    "section_links": [
      {
