        "url": "https://developer.mozilla.org/en-US/docs/Web/HTTP/Methods/PATCH",
        "section_id": "tutorial/body-updates::section-0004",
        "section_url": "https://fastapi.tiangolo.com/tutorial/body-updates/#partial-updates-with-patch"
      }
    ],
