          19,
          20,
          33
        ],
        "raw": "{* ../../docs_src/extra_models/tutorial003_py310.py hl[1,14:15,18:20,33] *}",
        "section_id": "tutorial/extra-models::section-0009",
        "section_url": "https://fastapi.tiangolo.com/tutorial/extra-models/#union-or-anyof"
      }
    ],
    "code_blocks": []
  },
  "tutorial/extra-models::section-0010": {
    "node_id": "tutorial/extra-models::section-0010",
    "parent_id": "tutorial/extra-models::section-0009",
    "level": 3,
    "node_kind": "heading",
    "heading_text": "Union in Python 3.10",
    "anchor_id": "union-in-python-3-10",
    "section_url": "https://fastapi.tiangolo.com/tutorial/extra-models/#union-in-python-3-10",
    "section_text": "In this example we pass Union[PlaneItem, CarItem] as the value of the argument response_model .\n\nBecause we are passing it as a value to an argument instead of putting it in a type annotation , we have to use Union even in Python 3.10.\n\nIf it was in a type annotation we could have used the vertical bar, as:\n\nBut if we put that in the assignment response_model=PlaneItem | CarItem we would get an error, because Python would try to perform an invalid operation between PlaneItem and CarItem instead of interpreting that as a type annotation.",
    "section_inline_code": [
      "Union",
      "Union[PlaneItem, CarItem]",
      "response_model",
      "response_model=PlaneItem | CarItem",
      "PlaneItem",
      "CarItem"
    ],
    "section_links": [],
    "code_refs": [],
    "code_blocks": [
      {
        "type": "code_block",
        "language": "Python",
        "text": "some_variable: PlaneItem | CarItem",
        "section_id": "tutorial/extra-models::section-0010",
        "section_url": "https://fastapi.tiangolo.com/tutorial/extra-models/#union-in-python-3-10"
      }
    ]
  },
