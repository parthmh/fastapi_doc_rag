  "tutorial/extra-models::section-0013": {
    "node_id": "tutorial/extra-models::section-0013",
    "parent_id": "tutorial/extra-models::section-0001",
    "level": 2,
    "node_kind": "heading",
    "heading_text": "Recap",
    "anchor_id": "recap",
    "section_url": "https://fastapi.tiangolo.com/tutorial/extra-models/#recap",
    "section_text": "Use multiple Pydantic models and inherit freely for each case.\n\nYou don't need to have a single data model per entity if that entity must be able to have different \"states\". As the case with the user \"entity\" with a state including password , password_hash and no password.",
    "section_inline_code": [
      "password",
      "password_hash"
    ],
