{
  "tutorial/path-params::section-0001": {
    "node_id": "tutorial/path-params::section-0001",
    "parent_id": null,
    "level": 1,
    "node_kind": "heading",
    "heading_text": "Path Parameters",
    "anchor_id": "path-parameters",
    "section_url": "https://fastapi.tiangolo.com/tutorial/path-params/#path-parameters",
    "section_text": "You can declare path \"parameters\" or \"variables\" with the same syntax used by Python format strings:\n\nThe value of the path parameter item_id will be passed to your function as the argument item_id .\n\nSo, if you run this example and go to http://127.0.0.1:8000/items/foo , you will see a response of:",
    "section_inline_code": [
      "item_id"
    ],
    "section_links": [
      {
        "text": "http://127.0.0.1:8000/items/foo",
        "url": "http://127.0.0.1:8000/items/foo",
        "section_id": "tutorial/path-params::section-0001",
        "section_url": "https://fastapi.tiangolo.com/tutorial/path-params/#path-parameters"
      }
    ],
    "code_refs": [
      {
        "type": "code_ref",
        "path": "../../docs_src/path_params/tutorial001_py310.py",
        "highlight_lines": [
          6,
          7
        ],
        "raw": "{* ../../docs_src/path_params/tutorial001_py310.py hl[6:7] *}",
        "section_id": "tutorial/path-params::section-0001",
        "section_url": "https://fastapi.tiangolo.com/tutorial/path-params/#path-parameters"
      }
    ],
    "code_blocks": [
      {
        "type": "code_block",
        "language": "JSON",
        "text": "{\"item_id\":\"foo\"}",
        "section_id": "tutorial/path-params::section-0001",
        "section_url": "https://fastapi.tiangolo.com/tutorial/path-params/#path-parameters"
      }
    ]
  },
