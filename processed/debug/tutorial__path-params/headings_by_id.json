  "tutorial/path-params::section-0018": {
    "node_id": "tutorial/path-params::section-0018",
    "parent_id": "tutorial/path-params::section-0017",
    "level": 3,
    "node_kind": "heading",
    "heading_text": "OpenAPI support",
    "anchor_id": "openapi-support",
    "section_url": "https://fastapi.tiangolo.com/tutorial/path-params/#openapi-support",
    "section_text": "OpenAPI doesn't support a way to declare a path parameter to contain a path inside, as that could lead to scenarios that are difficult to test and define.\n\nNevertheless, you can still do it in FastAPI , using one of the internal tools from Starlette.\n\nAnd the docs would still work, although not adding any documentation telling that the parameter should contain a path.",
    "section_inline_code": [],
    "section_links": [],
    "code_refs": [],
    "code_blocks": []
  },
  "tutorial/path-params::section-0019": {
    "node_id": "tutorial/path-params::section-0019",
    "parent_id": "tutorial/path-params::section-0017",
    "level": 3,
    "node_kind": "heading",
    "heading_text": "Path convertor",
    "anchor_id": "path-convertor",
    "section_url": "https://fastapi.tiangolo.com/tutorial/path-params/#path-convertor",
    "section_text": "Using an option directly from Starlette you can declare a path parameter containing a path using a URL like:\n\nIn this case, the name of the parameter is file_path , and the last part, :path , tells it that the parameter should match any path .\n\nSo, you can use it with:",
    "section_inline_code": [
      "file_path",
      ":path"
    ],
    "section_links": [],
    "code_refs": [
      {
        "type": "code_ref",
        "path": "../../docs_src/path_params/tutorial004_py310.py",
        "highlight_lines": [
          6
        ],
        "raw": "{* ../../docs_src/path_params/tutorial004_py310.py hl[6] *}",
        "section_id": "tutorial/path-params::section-0019",
        "section_url": "https://fastapi.tiangolo.com/tutorial/path-params/#path-convertor"
      }
    ],
    "code_blocks": [
      {
        "type": "code_block",
        "language": null,
        "text": "/files/{file_path:path}",
        "section_id": "tutorial/path-params::section-0019",
        "section_url": "https://fastapi.tiangolo.com/tutorial/path-params/#path-convertor"
      }
    ]
  },
