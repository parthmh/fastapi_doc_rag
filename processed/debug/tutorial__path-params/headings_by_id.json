    "level": 2,
    "node_kind": "heading",
    "heading_text": "Path parameters containing paths",
    "anchor_id": "path-parameters-containing-paths",
    "section_url": "https://fastapi.tiangolo.com/tutorial/path-params/#path-parameters-containing-paths",
    "section_text": "Let's say you have a path operation with a path /files/{file_path} .\n\nBut you need file_path itself to contain a path , like home/johndoe/myfile.txt .\n\nSo, the URL for that file would be something like: /files/home/johndoe/myfile.txt .",
    "section_inline_code": [
      "/files/{file_path}",
      "file_path",
      "home/johndoe/myfile.txt",
      "/files/home/johndoe/myfile.txt"
    ],
