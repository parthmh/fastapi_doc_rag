  },
  "tutorial/path-params::section-0004": {
    "node_id": "tutorial/path-params::section-0004",
    "parent_id": "tutorial/path-params::section-0001",
    "level": 2,
    "node_kind": "heading",
    "heading_text": "Data validation",
    "anchor_id": "data-validation",
    "section_url": "https://fastapi.tiangolo.com/tutorial/path-params/#data-validation",
    "section_text": "But if you go to the browser at http://127.0.0.1:8000/items/foo , you will see a nice HTTP error of:\n\nbecause the path parameter item_id had a value of \"foo\" , which is not an int .\n\nThe same error would appear if you provided a float instead of an int , as in: http://127.0.0.1:8000/items/4.2",
    "section_inline_code": [
      "item_id",
      "\"foo\"",
      "int",
      "float"
    ],
    "section_links": [
      {
        "text": "http://127.0.0.1:8000/items/foo",
        "url": "http://127.0.0.1:8000/items/foo",
        "section_id": "tutorial/path-params::section-0004",
        "section_url": "https://fastapi.tiangolo.com/tutorial/path-params/#data-validation"
      },
      {
        "text": "http://127.0.0.1:8000/items/4.2",
        "url": "http://127.0.0.1:8000/items/4.2",
        "section_id": "tutorial/path-params::section-0004",
        "section_url": "https://fastapi.tiangolo.com/tutorial/path-params/#data-validation"
      }
    ],
    "code_refs": [],
    "code_blocks": [
      {
        "type": "code_block",
        "language": "JSON",
        "text": "{\n  \"detail\": [\n    {\n      \"type\": \"int_parsing\",\n      \"loc\": [\n        \"path\",\n        \"item_id\"\n      ],\n      \"msg\": \"Input should be a valid integer, unable to parse string as an integer\",\n      \"input\": \"foo\"\n    }\n  ]\n}",
        "section_id": "tutorial/path-params::section-0004",
        "section_url": "https://fastapi.tiangolo.com/tutorial/path-params/#data-validation"
      }
    ]
  },
