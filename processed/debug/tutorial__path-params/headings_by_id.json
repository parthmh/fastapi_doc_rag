    "heading_text": "Data conversion",
    "anchor_id": "data-conversion",
    "section_url": "https://fastapi.tiangolo.com/tutorial/path-params/#data-conversion",
    "section_text": "If you run this example and open your browser at http://127.0.0.1:8000/items/3 , you will see a response of:",
    "section_inline_code": [],
    "section_links": [
