  "tutorial/path-params-numeric-validations::section-0005": {
    "node_id": "tutorial/path-params-numeric-validations::section-0005",
    "parent_id": "tutorial/path-params-numeric-validations::section-0001",
    "level": 2,
    "node_kind": "heading",
    "heading_text": "Order the parameters as you need, tricks",
    "anchor_id": "order-the-parameters-as-you-need-tricks",
    "section_url": "https://fastapi.tiangolo.com/tutorial/path-params-numeric-validations/#order-the-parameters-as-you-need-tricks",
    "section_text": "Here's a small trick that can be handy, but you won't need it often.\n\nIf you want to:\n\n- declare the q query parameter without a Query nor any default value\n\n- declare the path parameter item_id using Path\n\n- have them in a different order\n\n- not use Annotated\n\n...Python has a little special syntax for that.\n\nPass * , as the first parameter of the function.\n\nPython won't do anything with that * , but it will know that all the following parameters should be called as keyword arguments (key-value pairs), also known as kwargs . Even if they don't have a default value.",
    "section_inline_code": [
      "q",
      "Query",
      "item_id",
      "Path",
      "Annotated",
      "*"
    ],
    "section_links": [],
    "code_refs": [
      {
        "type": "code_ref",
        "path": "../../docs_src/path_params_numeric_validations/tutorial003_py310.py",
        "highlight_lines": [
          7
        ],
        "raw": "{* ../../docs_src/path_params_numeric_validations/tutorial003_py310.py hl[7] *}",
        "section_id": "tutorial/path-params-numeric-validations::section-0005",
        "section_url": "https://fastapi.tiangolo.com/tutorial/path-params-numeric-validations/#order-the-parameters-as-you-need-tricks"
      }
    ],
    "code_blocks": []
  },
