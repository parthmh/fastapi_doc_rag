    "parent_id": "tutorial/path-params-numeric-validations::section-0005",
    "level": 3,
    "node_kind": "heading",
    "heading_text": "Better with Annotated",
    "anchor_id": "better-with-annotated",
    "section_url": "https://fastapi.tiangolo.com/tutorial/path-params-numeric-validations/#better-with-annotated",
    "section_text": "Keep in mind that if you use Annotated , as you are not using function parameter default values, you won't have this problem, and you probably won't need to use * .",
    "section_inline_code": [
