  "tutorial/header-params::section-0005": {
    "node_id": "tutorial/header-params::section-0005",
    "parent_id": "tutorial/header-params::section-0001",
    "level": 2,
    "node_kind": "heading",
    "heading_text": "Duplicate headers",
    "anchor_id": "duplicate-headers",
    "section_url": "https://fastapi.tiangolo.com/tutorial/header-params/#duplicate-headers",
    "section_text": "It is possible to receive duplicate headers. That means, the same header with multiple values.\n\nYou can define those cases using a list in the type declaration.\n\nYou will receive all the values from the duplicate header as a Python list .\n\nFor example, to declare a header of X-Token that can appear more than once, you can write:\n\nIf you communicate with that path operation sending two HTTP headers like:\n\nThe response would be like:",
    "section_inline_code": [
      "list",
      "X-Token"
    ],
    "section_links": [],
    "code_refs": [
      {
        "type": "code_ref",
        "path": "../../docs_src/header_params/tutorial003_an_py310.py",
        "highlight_lines": [
          9
        ],
        "raw": "{* ../../docs_src/header_params/tutorial003_an_py310.py hl[9] *}",
        "section_id": "tutorial/header-params::section-0005",
        "section_url": "https://fastapi.tiangolo.com/tutorial/header-params/#duplicate-headers"
      }
    ],
    "code_blocks": [
      {
        "type": "code_block",
        "language": null,
        "text": "X-Token: foo\nX-Token: bar",
        "section_id": "tutorial/header-params::section-0005",
        "section_url": "https://fastapi.tiangolo.com/tutorial/header-params/#duplicate-headers"
      },
      {
        "type": "code_block",
        "language": "JSON",
        "text": "{\n    \"X-Token values\": [\n        \"bar\",\n        \"foo\"\n    ]\n}",
        "section_id": "tutorial/header-params::section-0005",
        "section_url": "https://fastapi.tiangolo.com/tutorial/header-params/#duplicate-headers"
      }
    ]
  },
